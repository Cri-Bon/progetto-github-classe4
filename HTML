<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studio Fotografico Milano</title>

  <link rel="stylesheet" href="style.css">
</head>

<body>

  <!-- NAVBAR -->
  <nav>
    <h2>Studio Foto Milano</h2>

    <ul>
      <li><a href="#home">Home</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#about">Chi Siamo</a></li>
      <li><a href="#contact">Contatti</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <header id="home">
    <div class="hero">
      <h1>Catturiamo Emozioni Autentiche</h1>

      <p>
        Ritratti, eventi aziendali e matrimoni con uno stile moderno,
        elegante e professionale.
      </p>

      <a href="#contact" class="btn">Richiedi un Preventivo</a>
    </div>
  </header>

  <!-- PORTFOLIO -->
  <section id="portfolio">

    <h2 class="section-title">Portfolio</h2>

    <div class="portfolio-grid">

      <div class="card">
        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1200&auto=format&fit=crop" alt="Ritratti">

        <h3>Ritratti</h3>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1511578314322-379afb476865?q=80&w=1200&auto=format&fit=crop" alt="Eventi">

        <h3>Eventi Aziendali</h3>
      </div>

      <div class="card">
        <img src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=1200&auto=format&fit=crop" alt="Matrimoni">

        <h3>Matrimoni</h3>
      </div>

    </div>
  </section>

  <!-- CHI SIAMO -->
  <section id="about">

    <h2 class="section-title">Chi Siamo</h2>

    <div class="about">

      <img
        src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop"
        alt="Team"
      >

      <div class="about-text">

        <h3>10 anni di esperienza nel settore fotografico</h3>

        <p>
          Siamo uno studio fotografico con sede a Milano specializzato
          in ritratti, eventi aziendali e servizi matrimoniali.
        </p>

        <br>

        <p>
          Il nostro obiettivo è raccontare emozioni vere attraverso immagini
          professionali e curate nei minimi dettagli.
        </p>

      </div>

    </div>

  </section>

  <!-- CONTATTI -->
  <section id="contact">

    <h2 class="section-title">Contattaci</h2>

    <form id="contactForm">

      <input type="text" id="name" placeholder="Nome" required>

      <input type="email" id="email" placeholder="Email" required>

      <select id="service" required>
        <option value="">Tipo di servizio richiesto</option>
        <option>Ritratto</option>
        <option>Evento Aziendale</option>
        <option>Matrimonio</option>
      </select>

      <textarea
        id="message"
        rows="6"
        placeholder="Messaggio"
      ></textarea>

      <button type="submit">Invia Richiesta</button>

    </form>

    <p id="successMessage"></p>

  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2025 Studio Foto Milano - Tutti i diritti riservati</p>
  </footer>

  <script src="script.js"></script>

</body>
</html>
